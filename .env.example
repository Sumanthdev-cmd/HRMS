SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

PUBLIC_APP_URL=https://your-hosted-app-url

# Recommended for hosted email on Render because it uses HTTPS instead of SMTP ports.
BREVO_API_KEY=your-brevo-api-key
EMAIL_FROM=AI-HRMS <your-verified-sender@gmail.com>

# Optional for local development or hosts that allow outbound SMTP.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=your-gmail-app-password

# Optional fallback if you later verify a domain in Resend.
RESEND_API_KEY=re_your_resend_api_key
